#!/bin/bash
# requires weasyprint and pandoc
# usage: genpdf input.md

set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: $0 <input.md>" >&2
    exit 1
fi

input="$1"

if [ ! -f "$input" ]; then
    echo "Error: input file '$input' not found" >&2
    exit 1
fi

output="${input%.*}.pdf"

pandoc "$input" -o "$output" --pdf-engine=weasyprint -c $HOME/.config/utils/assets/pdf-style.css
